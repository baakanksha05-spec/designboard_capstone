<!DOCTYPE html>
<html>
  <head>
    <meta charset="UTF-8">
    <title>Moodboard Result</title>

    <link
      rel="stylesheet"
      href="https://cdn.jsdelivr.net/npm/@picocss/pico@2/css/pico.min.css"
    >
  </head>

  <body>
    <main class="container">
      <h1>Your Moodboard</h1>

      <section>
        <h2>Vibe sentence</h2>
        <p><%= @moodboard.vibe_sentence %></p>
      </section>

      <% require "json" %>
      <% ai_hash = JSON.parse(@moodboard.ai_data_json) %>

      <section>
        <h2>Suggested items</h2>
        <ul>
          <% ai_hash.fetch("items").each do |item| %>
            <li>
              <strong><%= item.fetch("category") %>:</strong>
              <%= item.fetch("description") %><br>
              <em><%= item.fetch("why_it_works") %></em>
            </li>
          <% end %>
        </ul>
      </section>

      <section>
        <h2>Style rules cheat sheet</h2>
        <ol>
          <% ai_hash.fetch("style_rules").each do |rule| %>
            <li><%= rule %></li>
          <% end %>
        </ol>
      </section>

      <p>
        <a href="/">Generate another moodboard</a>
      </p>
    </main>
  </body>
</html>
