<!DOCTYPE html>
<html>
  <head>
    <meta charset="UTF-8">
    <title>Moodboard Generator</title>

    <!-- Optional: Pico or Bootstrap CDN to make it look decent -->
    <link
      rel="stylesheet"
      href="https://cdn.jsdelivr.net/npm/@picocss/pico@2/css/pico.min.css"
    >
  </head>

  <body>
    <main class="container">
      <h1>Moodboard Generator</h1>
      <p>Describe your room and vibe, e.g. “I want a Japandi living room that feels calm and bright, budget medium.”</p>

      <form action="/moodboards" method="post">
        <label for="vibe_sentence_field">Your vibe sentence</label>
        <textarea
          id="vibe_sentence_field"
          name="vibe_sentence"
          rows="4"
          required
        ></textarea>

        <button type="submit">Generate moodboard</button>
      </form>
    </main>
  </body>
</html>
