<!DOCTYPE html>
<html>
  <head>
    <meta charset="UTF-8">
    <title>The Home Atelier</title>

    <link
      rel="stylesheet"
      href="/home.css"
    >
  </head>

  <body>
    <div class="site-shell">
      <header class="site-header">
        <div class="site-title">The Home Atelier</div>
        <nav class="site-menu">
          <a href="/inspirations">My Inspirations</a>
          &nbsp;&nbsp;|&nbsp;&nbsp;
          <a href="/users/edit">Account</a>
          &nbsp;&nbsp;|&nbsp;&nbsp;
          <a href="/users/sign_out" data-method="delete">Log out</a>
        </nav>
      </header>

      <section class="hero">
        <div class="hero-left">
          <div class="hero-card">
            <div class="hero-eyebrow">Interior design studio</div>
            <h1 class="hero-title">
              Crafting<br>
              Memorable Spaces
            </h1>
            <p class="hero-body">
              The Home Atelier turns your inspiration photos into a
              step‑by‑step design plan – from key furniture pieces to
              styling rules you can follow in your own home.
            </p>
            <a href="#upload" class="hero-button">Start your project</a>

            <div id="upload" class="hero-form">
              <form action="/inspirations" method="post" enctype="multipart/form-data">
                <label for="photo_field">Upload your room photo</label>
                <div class="hero-form-row">
                  <input
                    id="photo_field"
                    type="file"
                    name="photo"
                    accept="image/*"
                    required
                  >

                  <div>
                    <label for="notes_field">Notes (budget, room type, vibe)</label>
                    <textarea id="notes_field" name="notes"></textarea>
                  </div>
                </div>

                <button type="submit">Generate my design plan</button>
              </form>
            </div>
          </div>
        </div>

        <div class="hero-right">
          <div class="hero-image-large"></div>
          <div class="hero-image-small"></div>
        </div>
      </section>

      <footer class="site-footer">
        <strong>Need more personalised advice?</strong>
        &nbsp;Email: design.studio@example.com &nbsp;|&nbsp;
        Instagram: @dreamroomdesigns
      </footer>
    </div>
  </body>
</html>
