<!DOCTYPE html>
<html>
  <head>
    <meta charset="UTF-8">
    <title>Upload your dream room</title>

    <link
      rel="stylesheet"
      href="https://cdn.jsdelivr.net/npm/@picocss/pico@2/css/pico.min.css"
    >
  </head>

  <body>
    <main class="container">
      <header style="display: flex; justify-content: space-between; align-items: center;">
        <h1>Turn your inspiration photo into a plan</h1>
        <nav>
          <a href="/inspirations">My inspirations</a>
          |
          <a href="/users/edit">Account settings</a>
          |
          <a href="/users/sign_out" data-method="delete">Log out</a>
        </nav>
      </header>

      <form action="/inspirations" method="post" enctype="multipart/form-data">
        <label for="photo_field">Upload your room photo</label>
        <input
          id="photo_field"
          type="file"
          name="photo"
          accept="image/*"
          required
        >

        <label for="notes_field">Notes (optional: budget, room type, etc.)</label>
        <textarea id="notes_field" name="notes" rows="3"></textarea>

        <button type="submit">Get design plan</button>
      </form>

      <footer style="margin-top: 2rem;">
        <hr>
        <p><strong>Need more personalised advice?</strong></p>
        <p>Email: design.studio@example.com &nbsp;|&nbsp; Instagram: @dreamroomdesigns</p>
      </footer>
    </main>
  </body>
</html>
